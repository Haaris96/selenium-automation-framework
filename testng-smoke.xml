<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Selenium Automation Framework - Smoke Suite"
       verbose="2"
       thread-count="1"
       parallel="none">

    <listeners>
        <listener class-name="com.framework.listeners.TestListener"/>
        <listener class-name="com.framework.listeners.ExtentReportListener"/>
        <listener class-name="com.framework.retry.RetryAnnotationTransformer"/>
    </listeners>

    <test name="Smoke Tests">
        <parameter name="browser" value="chrome"/>
        <parameter name="env"     value="qa"/>
        <groups>
            <run>
                <include name="smoke"/>
            </run>
        </groups>
        <classes>
            <class name="com.framework.tests.LoginTest"/>
            <class name="com.framework.tests.ShoppingTest"/>
        </classes>
    </test>

</suite>
