<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="Selenium Automation Framework - Regression Suite"
       verbose="2"
       thread-count="1"
       parallel="none">

    <listeners>
        <listener class-name="com.framework.listeners.TestListener"/>
        <listener class-name="com.framework.listeners.ExtentReportListener"/>
        <listener class-name="com.framework.retry.RetryAnnotationTransformer"/>
    </listeners>

    <!-- TestNG-based tests -->
    <test name="Login Tests" preserve-order="true">
        <parameter name="browser" value="chrome"/>
        <parameter name="env"     value="qa"/>
        <groups>
            <run>
                <include name="smoke"/>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="com.framework.tests.LoginTest"/>
        </classes>
    </test>

    <test name="Shopping Tests" preserve-order="true">
        <parameter name="browser" value="chrome"/>
        <parameter name="env"     value="qa"/>
        <groups>
            <run>
                <include name="smoke"/>
                <include name="regression"/>
            </run>
        </groups>
        <classes>
            <class name="com.framework.tests.ShoppingTest"/>
        </classes>
    </test>

    <!-- BDD Cucumber runner -->
    <test name="Cucumber BDD Tests">
        <parameter name="browser" value="chrome"/>
        <parameter name="env"     value="qa"/>
        <classes>
            <class name="com.framework.runners.CucumberRunner"/>
        </classes>
    </test>

</suite>
